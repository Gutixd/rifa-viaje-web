# ─── Supabase ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# ─── Admin ────────────────────────────────────────────────────────────
# Contraseña para el panel administrador
ADMIN_PASSWORD=tu-contraseña-segura
# Secreto aleatorio (mínimo 32 caracteres) para la cookie de sesión
ADMIN_SESSION_SECRET=genera-un-string-aleatorio-largo-aqui

# ─── Telegram ─────────────────────────────────────────────────────────
# Token del bot (obtén uno en @BotFather)
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Chat ID de tu cuenta o grupo (usa @userinfobot para obtenerlo)
TELEGRAM_CHAT_ID=-100xxxxxxxxxx

# ─── App ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://tu-dominio.vercel.app

# ─── Cron (Vercel) ────────────────────────────────────────────────────
# Secreto para proteger el endpoint de limpieza automática
CRON_SECRET=otro-string-aleatorio-seguro
